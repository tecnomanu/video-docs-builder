{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "scripts"
  },
  "include": ["scripts/**/*"],
  "exclude": ["node_modules", "dist", "output"]
}
