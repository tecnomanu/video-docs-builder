# ── TTS Provider ──────────────────────────────────────────────────────────────
# elevenlabs (default) | openai | google | piper
# piper = FREE, local, Daniela voice (es_AR native accent) — no API needed
TTS_PROVIDER=elevenlabs

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Free plan voices (work in Spanish with eleven_multilingual_v2):
#   EXAVITQu4vr4xnSDxMaL  Bella   (default — warm, feminine)
#   pNInz6obpgDQGcFmaJgB  Adam    (masculine)
# Paid plan library voices (native Spanish, better accent):
#   jw1XYij1FCiI9FENSxIf  Martina (Argentine/Latin — requires Starter $5/mo)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── OpenAI TTS (alternative — no English accent in Spanish) ───────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_VOICE=nova       # nova | shimmer | alloy | echo | onyx | fable
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_SPEED=0.92   # slightly slower = easier to follow

# ── Google Gemini TTS (natural voices, great Spanish — requires GEMINI_API_KEY) ─
# GEMINI_API_KEY=AIzaSy...
# GEMINI_VOICE=Kore       # Kore (warm feminine) | Aoede | Charon (masculine) | Puck
#                         # Full list: Achird Algieba Alnilam Autonoe Callirrhoe
#                         #   Despina Enceladus Erinome Fenrir Gacrux Iocaste Izar
#                         #   Laomedeia Leda Meissa Mimas Mintaka Mira Murzim
#                         #   Nashira Navi Nereid Oberon Pulcherrima Rasalas
#                         #   Schedar Sulafat Umbriel Vindemiatrix Wasat Zubenelgenubi
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Per-language override: GEMINI_VOICE_ES=Kore  GEMINI_VOICE_EN=Aoede

# ── Piper TTS (FREE — local or AMD/NVIDIA server) ─────────────────────────────
# Run: cd tools/piper-tts && ./setup.sh
# Then set TTS_PROVIDER=piper above.
# PIPER_VOICE=es_AR-daniela-high   # Daniela — voz argentina nativa
#              es_MX-claude-high   # Claude — voz mexicana (más alegre)
#              es_MX-ald-medium    # Ald — voz mexicana alternativa
# PIPER_SPEED=0.95                 # 0.8=lento, 1.0=normal, 1.2=rápido
# PIPER_NOISE_SCALE=0.9            # 0.667=neutro, 0.9=expresivo, 1.2=muy expresivo
# PIPER_SERVER_URL=                # http://your-server:8090 for GPU server
