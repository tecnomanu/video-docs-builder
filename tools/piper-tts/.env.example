# ── Piper TTS Configuration ───────────────────────────────────────────────

# Voice model name (without .onnx extension)
# Available voices in voices/ directory
PIPER_VOICE=es_AR-daniela-high

# Speed: 0.8 (slower/clearer) | 1.0 (normal) | 1.2 (faster)
PIPER_SPEED=0.95

# Expressiveness: 0.667 (flat/neutral, default) | 1.0 (more varied/cheerful) | 1.5 (very expressive)
# Higher noise_scale = more pitch variation and expression
PIPER_NOISE_SCALE=0.9

# Remote server URL (optional — leave empty for local inference)
# Set this to use your AMD Radeon server for GPU-accelerated synthesis
# Example: PIPER_SERVER_URL=http://192.168.1.100:8090
PIPER_SERVER_URL=
